# Outlier detection using IQR method
Q1 = data["population"].quantile(0.25)
Q3 = data["population"].quantile(0.75)

IQR = Q3 - Q1

lower = Q1 - 1.5 * IQR
upper = Q3 + 1.5 * IQR
</VSCode.Cell>
<VSCode.Cell language="python">
outliers = data[
    (data["population"] < lower) |
    (data["population"] > upper)
]

print(len(outliers))
