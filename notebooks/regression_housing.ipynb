    "# Outlier detection using IQR method\n",
    "Q1 = data[\"population\"].quantile(0.25)\n",
    "Q3 = data[\"population\"].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR"
   ]
